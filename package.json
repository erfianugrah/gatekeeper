{
	"name": "gatekeeper",
	"version": "1.2.0",
	"private": true,
	"license": "MIT",
	"type": "module",
	"scripts": {
		"dev": "wrangler dev",
		"start": "wrangler dev",
		"build": "bun run build:dashboard && bun run build:cli",
		"build:dashboard": "cd dashboard && bun run build",
		"build:cli": "tsc -p cli/tsconfig.json",
		"typecheck": "tsc --noEmit && tsc -p cli/tsconfig.json --noEmit",
		"lint": "prettier --check 'src/**/*.ts' 'cli/**/*.ts' 'test/**/*.ts' 'scripts/**/*.ts'",
		"lint:fix": "prettier --write 'src/**/*.ts' 'cli/**/*.ts' 'test/**/*.ts' 'scripts/**/*.ts'",
		"test": "vitest run",
		"test:worker": "vitest run -c vitest.worker.config.ts",
		"test:cli": "vitest run -c vitest.cli.config.ts",
		"test:e2e": "playwright test",
		"preflight": "bun run typecheck && bun run lint && bun run test && bun run check:openapi && bun run build",
		"check:openapi": "bash scripts/check-openapi.sh",
		"check:api-coverage": "tsx scripts/api-coverage/refresh.ts",
		"api-coverage:write": "tsx scripts/api-coverage/refresh.ts --write",
		"deploy": "bun run build:dashboard && wrangler deploy",
		"deploy:staging": "bun run build:dashboard && wrangler deploy --env staging",
		"ship": "bun run preflight && bun run deploy",
		"ship:staging": "bun run preflight && bun run deploy:staging",
		"cf-typegen": "wrangler types",
		"cli": "node --env-file=.env --import tsx cli/index.ts",
		"smoke": "node --env-file=.env --import tsx cli/smoke-test.ts",
		"openapi": "tsx scripts/generate-openapi.ts"
	},
	"devDependencies": {
		"@cloudflare/vitest-pool-workers": "^0.12.19",
		"@playwright/test": "^1.58.2",
		"@types/node": "^25.3.3",
		"aws4fetch": "^1.0.20",
		"citty": "^0.2.1",
		"hono": "^4.12.5",
		"prettier": "^3.8.1",
		"tsx": "^4.21.0",
		"typescript": "^5.5.2",
		"vitest": "~3.2.0",
		"wrangler": "^4.70.0",
		"zod": "^4.3.6",
		"zod-openapi": "^5.4.6"
	},
	"dependencies": {
		"arctic": "^3.7.0"
	}
}
